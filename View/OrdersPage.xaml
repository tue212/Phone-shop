<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PhoneShop.View.OrdersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PhoneShop.View"
    xmlns:vm="using:PhoneShop.ViewModel"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:local1="using:PhoneShop.Converters"
    mc:Ignorable="d">

    <Page.DataContext>
        <vm:OrdersViewModel/>
    </Page.DataContext>

    <Page.Resources>
        <local1:NumberConverter x:Key="NumberConverter"/>
    </Page.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Quản lý đơn hàng" FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="Danh sách đơn hàng bán sản phẩm" FontSize="14" Opacity="0.7"/>
        </StackPanel>

        <!-- CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- LIST -->
            <Border Grid.Column="0" 
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="15" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{x:Bind ViewModel.SearchText, Mode=TwoWay}" 
                                 PlaceholderText="Tìm kiếm..." MaxWidth="200" HorizontalAlignment="Left"/>
                        <Button Grid.Column="1" Content="Tìm" Click="Search_Click"/>
                    </Grid>

                    <!-- DataGrid -->
                    <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.FilteredOrders}"
                                SelectedItem="{x:Bind ViewModel.SelectedOrder}"
                                SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Margin="5" Text="{Binding OrderId}"/>
                                    <TextBlock Grid.Column="1" Margin="5" Text="{Binding OrderDate, Converter={StaticResource NumberConverter}}"/>
                                    <TextBlock Grid.Column="2" Margin="5" Text="{Binding CustomerName}"/>
                                    <TextBlock Grid.Column="3" Margin="5" Text="{Binding TotalAmount, Converter={StaticResource NumberConverter}}"/>
                                    <TextBlock Grid.Column="4" Margin="5" Text="{Binding Status}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- FORM -->
            <Border Grid.Column="1" 
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="15">
                <StackPanel>
                    <TextBlock Text="Chi tiết đơn hàng" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15"/>

                    <TextBlock Text="Mã đơn hàng" FontSize="12" Opacity="0.7"/>
                    <TextBlock Text="{x:Bind ViewModel.SelectedOrder.OrderId, Mode=OneWay}" FontWeight="Bold" Margin="0,0,0,10"/>

                    <TextBlock Text="Tên khách hàng" FontSize="12" Opacity="0.7"/>
                    <TextBlock Text="{x:Bind ViewModel.SelectedOrder.CustomerName, Mode=OneWay}" Margin="0,0,0,10"/>

                    <TextBlock Text="Số điện thoại" FontSize="12" Opacity="0.7"/>
                    <TextBlock Text="{x:Bind ViewModel.SelectedOrder.CustomerPhone, Mode=OneWay}" Margin="0,0,0,10"/>

                    <TextBlock Text="Địa chỉ" FontSize="12" Opacity="0.7"/>
                    <TextBlock Text="{x:Bind ViewModel.SelectedOrder.CustomerAddress, Mode=OneWay}" TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <TextBlock Text="Giảm giá" FontSize="12" Opacity="0.7"/>
                    <TextBlock Text="{x:Bind ViewModel.SelectedOrder.Discount, Converter={StaticResource NumberConverter}, Mode=OneWay}" Margin="0,0,0,10"/>

                    <TextBlock Text="Đã thanh toán" FontSize="12" Opacity="0.7"/>
                    <TextBlock Text="{x:Bind ViewModel.SelectedOrder.PaidAmount, Converter={StaticResource NumberConverter}, Mode=OneWay}" Margin="0,0,0,10"/>

                    <TextBlock Text="Còn nợ" FontSize="12" Opacity="0.7"/>
                    <TextBlock Text="{x:Bind ViewModel.SelectedOrder.RemainingAmount, Converter={StaticResource NumberConverter}, Mode=OneWay}" 
                               Foreground="Red" FontWeight="Bold" Margin="0,0,0,10"/>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                        <Button Content="Xác nhận" Click="Confirm_Click" Margin="0,0,5,0"/>
                        <Button Content="Hủy" Click="CancelOrder_Click"/>
                    </StackPanel>

                    <Button Content="Xóa đơn" Click="Delete_Click" 
                            HorizontalAlignment="Left" Margin="0,10,0,0"
                            Foreground="Red"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
