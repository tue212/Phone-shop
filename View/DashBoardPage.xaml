<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PhoneShop.View.DashBoardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PhoneShop.View"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="350"/>
                <RowDefinition Height="250"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Dashboard" 
                           FontSize="28" 
                           FontWeight="Bold"/>
                    <TextBlock Text="Tổng quan hệ thống cửa hàng điện thoại" 
                           FontSize="14" 
                           Opacity="0.7"
                           Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Ngày hiện tại & User -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="15,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" 
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="todayTextBlock" Text="Hôm nay: --/--/----" 
                                   VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="15,8" Margin="10,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" 
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Admin" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ROW 1: STAT CARDS -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Card 1: Doanh thu hôm nay -->
                <Border Grid.Column="0" 
                    Background="#4CAF50" 
                    CornerRadius="12" 
                    Padding="20" 
                    Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" 
                               FontSize="24" Foreground="White" Opacity="0.8"/>
                        <TextBlock Text="Doanh thu hôm nay" 
                               Foreground="White" 
                               FontSize="14" 
                               Margin="0,15,0,5"
                               Opacity="0.9"/>
                        <TextBlock x:Name="revenueTodayText" 
                               Text="150.000.000 đ" 
                               Foreground="White" 
                               FontSize="24" 
                               FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="&#xE74B;" FontFamily="Segoe MDL2 Assets" 
                                   Foreground="#90EE90" FontSize="12"/>
                            <TextBlock Text=" +12%" Foreground="#90EE90" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Card 2: Đơn hàng hôm nay -->
                <Border Grid.Column="1" 
                    Background="#2196F3" 
                    CornerRadius="12" 
                    Padding="20" 
                    Margin="5,0,5,0">
                    <StackPanel>
                        <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" 
                               FontSize="24" Foreground="White" Opacity="0.8"/>
                        <TextBlock Text="Đơn hàng hôm nay" 
                               Foreground="White" 
                               FontSize="14" 
                               Margin="0,15,0,5"
                               Opacity="0.9"/>
                        <TextBlock x:Name="ordersTodayText" 
                               Text="12" 
                               Foreground="White" 
                               FontSize="24" 
                               FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="&#xE74B;" FontFamily="Segoe MDL2 Assets" 
                                   Foreground="#90EE90" FontSize="12"/>
                            <TextBlock Text=" +5" Foreground="#90EE90" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Card 3: Tồn kho -->
                <Border Grid.Column="2" 
                    Background="#FF9800" 
                    CornerRadius="12" 
                    Padding="20" 
                    Margin="5,0,5,0">
                    <StackPanel>
                        <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" 
                               FontSize="24" Foreground="White" Opacity="0.8"/>
                        <TextBlock Text="Tổng tồn kho" 
                               Foreground="White" 
                               FontSize="14" 
                               Margin="0,15,0,5"
                               Opacity="0.9"/>
                        <TextBlock x:Name="inventoryText" 
                               Text="85" 
                               Foreground="White" 
                               FontSize="24" 
                               FontWeight="Bold"/>
                        <TextBlock Text="sản phẩm" 
                               Foreground="White" 
                               FontSize="12" 
                               Opacity="0.8"/>
                    </StackPanel>
                </Border>

                <!-- Card 4: Đơn chờ xử lý -->
                <Border Grid.Column="3" 
                    Background="#F44336" 
                    CornerRadius="12" 
                    Padding="20" 
                    Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" 
                               FontSize="24" Foreground="White" Opacity="0.8"/>
                        <TextBlock Text="Đơn chờ xử lý" 
                               Foreground="White" 
                               FontSize="14" 
                               Margin="0,15,0,5"
                               Opacity="0.9"/>
                        <TextBlock x:Name="pendingOrdersText" 
                               Text="3" 
                               Foreground="White" 
                               FontSize="24" 
                               FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="Cần xác nhận" 
                                   Foreground="White" 
                                   FontSize="12" 
                                   Opacity="0.8"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ROW 2: BIỂU ĐỒ -->
            <Grid Grid.Row="2" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Biểu đồ doanh thu 7 ngày -->
                <Border Grid.Column="0" 
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12" 
                    Padding="20" 
                    Margin="0,0,10,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Doanh thu 7 ngày gần nhất" 
                               FontSize="16" 
                               FontWeight="SemiBold"/>

                        <!-- Placeholder cho biểu đồ (thay bằng chart control khi có thư viện) -->
                        <Grid Grid.Row="1" Margin="0,20,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Các cột biểu đồ -->
                            <StackPanel Grid.Row="0" 
                                    Orientation="Horizontal" 
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Bottom">
                                <!-- Ngày 1 -->
                                <StackPanel Margin="5,0">
                                    <Border Width="40" Height="100" Background="#4CAF50" 
                                        CornerRadius="4,4,0,0" VerticalAlignment="Bottom"/>
                                    <TextBlock Text="T7" HorizontalAlignment="Center" 
                                           FontSize="11" Margin="0,5,0,0"/>
                                </StackPanel>
                                <!-- Ngày 2 -->
                                <StackPanel Margin="5,0">
                                    <Border Width="40" Height="140" Background="#4CAF50" 
                                        CornerRadius="4,4,0,0" VerticalAlignment="Bottom"/>
                                    <TextBlock Text="T6" HorizontalAlignment="Center" 
                                           FontSize="11" Margin="0,5,0,0"/>
                                </StackPanel>
                                <!-- Ngày 3 -->
                                <StackPanel Margin="5,0">
                                    <Border Width="40" Height="80" Background="#4CAF50" 
                                        CornerRadius="4,4,0,0" VerticalAlignment="Bottom"/>
                                    <TextBlock Text="T5" HorizontalAlignment="Center" 
                                           FontSize="11" Margin="0,5,0,0"/>
                                </StackPanel>
                                <!-- Ngày 4 -->
                                <StackPanel Margin="5,0">
                                    <Border Width="40" Height="180" Background="#4CAF50" 
                                        CornerRadius="4,4,0,0" VerticalAlignment="Bottom"/>
                                    <TextBlock Text="T4" HorizontalAlignment="Center" 
                                           FontSize="11" Margin="0,5,0,0"/>
                                </StackPanel>
                                <!-- Ngày 5 -->
                                <StackPanel Margin="5,0">
                                    <Border Width="40" Height="120" Background="#4CAF50" 
                                        CornerRadius="4,4,0,0" VerticalAlignment="Bottom"/>
                                    <TextBlock Text="T3" HorizontalAlignment="Center" 
                                           FontSize="11" Margin="0,5,0,0"/>
                                </StackPanel>
                                <!-- Ngày 6 -->
                                <StackPanel Margin="5,0">
                                    <Border Width="40" Height="160" Background="#4CAF50" 
                                        CornerRadius="4,4,0,0" VerticalAlignment="Bottom"/>
                                    <TextBlock Text="T2" HorizontalAlignment="Center" 
                                           FontSize="11" Margin="0,5,0,0"/>
                                </StackPanel>
                                <!-- Ngày 7 (Hôm nay) -->
                                <StackPanel Margin="5,0">
                                    <Border Width="40" Height="200" Background="#FF9800" 
                                        CornerRadius="4,4,0,0" VerticalAlignment="Bottom"/>
                                    <TextBlock Text="HN" HorizontalAlignment="Center" 
                                           FontSize="11" Margin="0,5,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Trục Y (giá trị) -->
                            <StackPanel Grid.Row="0" 
                                    Orientation="Horizontal" 
                                    HorizontalAlignment="Left"
                                    Margin="-30,0,0,0">
                                <TextBlock Text="200M" FontSize="10" Opacity="0.6"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Top sản phẩm bán chạy -->
                <Border Grid.Column="1" 
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12" 
                    Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE734;" FontFamily="Segoe MDL2 Assets" 
                                   FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Sản phẩm bán chạy" 
                                   FontSize="16" 
                                   FontWeight="SemiBold"/>
                        </StackPanel>

                        <ListView Grid.Row="1" Margin="0,15,0,0" 
                              ItemsSource="{x:Null}" 
                              IsItemClickEnabled="False">
                            <ListViewItem Padding="8">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="28" Height="28" Background="#FFD700" 
                                        CornerRadius="14" Margin="0,0,10,0">
                                        <TextBlock Text="1" HorizontalAlignment="Center" 
                                               VerticalAlignment="Center" 
                                               FontWeight="Bold" FontSize="12"/>
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="iPhone 15 Pro" FontWeight="SemiBold"/>
                                        <TextBlock Text="Đã bán: 25" FontSize="11" Opacity="0.7"/>
                                    </StackPanel>
                                </StackPanel>
                            </ListViewItem>
                            <ListViewItem Padding="8">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="28" Height="28" Background="#C0C0C0" 
                                        CornerRadius="14" Margin="0,0,10,0">
                                        <TextBlock Text="2" HorizontalAlignment="Center" 
                                               VerticalAlignment="Center" 
                                               FontWeight="Bold" FontSize="12"/>
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="Samsung S24 Ultra" FontWeight="SemiBold"/>
                                        <TextBlock Text="Đã bán: 18" FontSize="11" Opacity="0.7"/>
                                    </StackPanel>
                                </StackPanel>
                            </ListViewItem>
                            <ListViewItem Padding="8">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="28" Height="28" Background="#CD7F32" 
                                        CornerRadius="14" Margin="0,0,10,0">
                                        <TextBlock Text="3" HorizontalAlignment="Center" 
                                               VerticalAlignment="Center" 
                                               FontWeight="Bold" FontSize="12"/>
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="Xiaomi 14 Pro" FontWeight="SemiBold"/>
                                        <TextBlock Text="Đã bán: 15" FontSize="11" Opacity="0.7"/>
                                    </StackPanel>
                                </StackPanel>
                            </ListViewItem>
                            <ListViewItem Padding="8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="4" FontWeight="Bold" 
                                           Width="28" TextAlignment="Center"/>
                                    <StackPanel>
                                        <TextBlock Text="iPhone 15" FontWeight="SemiBold"/>
                                        <TextBlock Text="Đã bán: 12" FontSize="11" Opacity="0.7"/>
                                    </StackPanel>
                                </StackPanel>
                            </ListViewItem>
                            <ListViewItem Padding="8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="5" FontWeight="Bold" 
                                           Width="28" TextAlignment="Center"/>
                                    <StackPanel>
                                        <TextBlock Text="OPPO Reno12" FontWeight="SemiBold"/>
                                        <TextBlock Text="Đã bán: 10" FontSize="11" Opacity="0.7"/>
                                    </StackPanel>
                                </StackPanel>
                            </ListViewItem>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>

            <!-- ROW 3: CẢNH BÁO & ĐƠN HÀNG GẦN ĐÂY -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Cảnh báo tồn kho -->
                <Border Grid.Column="0" 
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12" 
                    Padding="20" 
                    Margin="0,0,10,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" 
                                   FontSize="18" Margin="0,0,8,0" 
                                   Foreground="#FF9800" VerticalAlignment="Center"/>
                            <TextBlock Text="Cảnh báo tồn kho thấp" 
                                   FontSize="16" 
                                   FontWeight="SemiBold"/>
                        </StackPanel>

                        <ListView Grid.Row="1" Margin="0,15,0,0">
                            <ListViewItem Padding="10,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="iPhone 14 Pro 256GB" FontWeight="SemiBold"/>
                                        <TextBlock Text="Màu: Xanh lá" FontSize="11" Opacity="0.7"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="#F44336" 
                                        CornerRadius="4" Padding="8,4">
                                        <TextBlock Text="Còn 2 cái" Foreground="White" 
                                               FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </ListViewItem>
                            <ListViewItem Padding="10,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Samsung Galaxy A54" FontWeight="SemiBold"/>
                                        <TextBlock Text="Màu: Đen" FontSize="11" Opacity="0.7"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="#F44336" 
                                        CornerRadius="4" Padding="8,4">
                                        <TextBlock Text="Còn 3 cái" Foreground="White" 
                                               FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </ListViewItem>
                            <ListViewItem Padding="10,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Xiaomi Redmi Note 12" FontWeight="SemiBold"/>
                                        <TextBlock Text="Màu: Trắng" FontSize="11" Opacity="0.7"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="#FF9800" 
                                        CornerRadius="4" Padding="8,4">
                                        <TextBlock Text="Còn 4 cái" Foreground="White" 
                                               FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </ListViewItem>
                        </ListView>
                    </Grid>
                </Border>

                <!-- Đơn hàng gần đây -->
                <Border Grid.Column="1" 
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12" 
                    Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" 
                                   FontSize="18" Margin="0,0,8,0" 
                                   Foreground="#2196F3" VerticalAlignment="Center"/>
                            <TextBlock Text="Đơn hàng gần đây" 
                                   FontSize="16" 
                                   FontWeight="SemiBold"/>
                        </StackPanel>

                        <ListView Grid.Row="1" Margin="0,15,0,0">
                            <ListViewItem Padding="10,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#2196F3" 
                                        CornerRadius="4" Padding="8,4">
                                        <TextBlock Text="#001" Foreground="White" 
                                               FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="10,0">
                                        <TextBlock Text="Nguyễn Văn A" FontWeight="SemiBold"/>
                                        <TextBlock Text="3 sản phẩm" FontSize="11" Opacity="0.7"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="45.000.000 đ" 
                                           FontWeight="SemiBold" 
                                           Foreground="#4CAF50"/>
                                </Grid>
                            </ListViewItem>
                            <ListViewItem Padding="10,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#2196F3" 
                                        CornerRadius="4" Padding="8,4">
                                        <TextBlock Text="#002" Foreground="White" 
                                               FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="10,0">
                                        <TextBlock Text="Trần Thị B" FontWeight="SemiBold"/>
                                        <TextBlock Text="1 sản phẩm" FontSize="11" Opacity="0.7"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="28.000.000 đ" 
                                           FontWeight="SemiBold" 
                                           Foreground="#4CAF50"/>
                                </Grid>
                            </ListViewItem>
                            <ListViewItem Padding="10,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#2196F3" 
                                        CornerRadius="4" Padding="8,4">
                                        <TextBlock Text="#003" Foreground="White" 
                                               FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="10,0">
                                        <TextBlock Text="Lê Văn C" FontWeight="SemiBold"/>
                                        <TextBlock Text="2 sản phẩm" FontSize="11" Opacity="0.7"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="15.500.000 đ" 
                                           FontWeight="SemiBold" 
                                           Foreground="#4CAF50"/>
                                </Grid>
                            </ListViewItem>
                            <ListViewItem Padding="10,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#2196F3" 
                                        CornerRadius="4" Padding="8,4">
                                        <TextBlock Text="#004" Foreground="White" 
                                               FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="10,0">
                                        <TextBlock Text="Phạm Thị D" FontWeight="SemiBold"/>
                                        <TextBlock Text="1 sản phẩm" FontSize="11" Opacity="0.7"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="22.000.000 đ" 
                                           FontWeight="SemiBold" 
                                           Foreground="#4CAF50"/>
                                </Grid>
                            </ListViewItem>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
