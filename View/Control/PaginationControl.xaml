<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PhoneShop.View.Control.PaginationControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PhoneShop.View.Control"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Orientation="Vertical" Spacing="6">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
            <Button Content="&lt;&lt;" Click="FirstPage_Click"/>
            <Button Content="&lt;" Click="PrevPage_Click"/>
            <TextBlock Text="{x:Bind PageInfo, Mode=OneWay}" VerticalAlignment="Center" FontWeight="SemiBold" Margin="10, 0"/>
            <Button Content="&gt;" Click="NextPage_Click"/>
            <Button Content="&gt;&gt;" Click="LastPage_Click"/>
        </StackPanel>
        <TextBlock Text="{x:Bind ItemsInfo, Mode=OneWay}" HorizontalAlignment="Center" FontSize="12" Opacity="0.7"/>
    </StackPanel>
</UserControl>
